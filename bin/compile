#!/usr/bin/env php
<?php
/**
 * Compiles MCP4Joomla into a self-extracting PHAR archive.
 *
 * Usage: php -d phar.readonly=0 bin/compile
 *   or:  composer compile
 *
 * @package   joomla-mcp-php
 * @copyright (c) 2025 Nicholas K. Dionysopoulos
 * @license   AGPL-3.0-or-later
 */

declare(strict_types=1);

// Ensure phar.readonly is off.
if (ini_get('phar.readonly'))
{
	fwrite(STDERR, <<<'END'
	Error: phar.readonly is enabled in your PHP configuration.

	Run this script with:
	  php -d phar.readonly=0 bin/compile
	  or
	  composer compile

	END);
	exit(1);
}

$projectRoot = dirname(__DIR__);
$buildDir    = $projectRoot . '/build';
$stagingDir  = $buildDir . '/staging';
$pharFile    = $buildDir . '/mcp4joomla.phar';

// Load version.
require $projectRoot . '/version.php';
$version = MCP4JOOMLA_VERSION;

echo "Building MCP4Joomla v{$version} PHAR archive...\n\n";

// Clean previous build.
if (file_exists($pharFile))
{
	unlink($pharFile);
}

if (is_dir($stagingDir))
{
	deleteDirectory($stagingDir);
}

// Create staging directory with production dependencies only.
echo "[1/5] Creating staging directory with production dependencies...\n";
mkdir($stagingDir, 0755, true);
copy($projectRoot . '/composer.json', $stagingDir . '/composer.json');
copy($projectRoot . '/composer.lock', $stagingDir . '/composer.lock');

$composerCmd = sprintf(
	'cd %s && composer install --no-dev --no-scripts --prefer-dist --no-interaction --quiet 2>&1',
	escapeshellarg($stagingDir)
);
$output      = [];
$exitCode    = 0;
exec($composerCmd, $output, $exitCode);

if ($exitCode !== 0)
{
	fwrite(STDERR, "Error: composer install failed:\n" . implode("\n", $output) . "\n");
	deleteDirectory($stagingDir);
	exit(1);
}

echo "  Done.\n";

// Create the PHAR.
echo "[2/5] Building PHAR archive...\n";

$phar = new Phar($pharFile);
$phar->startBuffering();

// Add project files.
addFile($phar, $projectRoot . '/mcp4joomla.php', 'mcp4joomla.php');
addFile($phar, $projectRoot . '/version.php', 'version.php');
addFile($phar, $projectRoot . '/LICENSE', 'LICENSE');

// Add src/ tree.
addDirectory($phar, $projectRoot . '/src', 'src');

// Add vendor/ from staging (with exclusions).
$excludePatterns = [
	'/tests/',
	'/Tests/',
	'/test/',
	'/Test/',
	'/docs/',
	'/doc/',
	'/examples/',
	'/example/',
	'/.git/',
	'/.github/',
	'/vendor/bin/',
];
addDirectory($phar, $stagingDir . '/vendor', 'vendor', $excludePatterns);

echo "  Done.\n";

// Set the self-extracting stub.
echo "[3/5] Setting self-extracting stub...\n";

$stub = <<<'STUB'
#!/usr/bin/env php
<?php
/**
 * MCP4Joomla self-extracting PHAR stub.
 *
 * Extracts the PHAR contents to a temp directory (cached by content hash)
 * and runs the extracted mcp4joomla.php. This avoids realpath() issues
 * with phar:// paths in php-mcp/server's discovery mechanism.
 */

$pharPath = Phar::running(false);

if ($pharPath === '')
{
	// Fallback when Phar::running() returns empty (e.g. php phar.phar invocation).
	$pharPath = realpath($_SERVER['SCRIPT_FILENAME'] ?? $_SERVER['argv'][0] ?? '');
}

$pharHash   = md5_file($pharPath);
$extractDir = sys_get_temp_dir() . '/mcp4joomla-' . $pharHash;

if (!is_dir($extractDir . '/src'))
{
	$phar = new Phar($pharPath);
	$phar->extractTo($extractDir, null, true);
}

// Pass through to the extracted entry point.
$_SERVER['argv'][0] = $extractDir . '/mcp4joomla.php';
require $extractDir . '/mcp4joomla.php';

__HALT_COMPILER();
STUB;

$phar->setStub($stub);

echo "  Done.\n";

// Compress files.
echo "[4/5] Compressing files with GZ...\n";

if (Phar::canCompress(Phar::GZ))
{
	$phar->compressFiles(Phar::GZ);
	echo "  Done.\n";
}
else
{
	echo "  GZ compression not available, skipping.\n";
}

$phar->stopBuffering();

// Make executable.
chmod($pharFile, 0755);

// Clean up staging.
echo "[5/5] Cleaning up staging directory...\n";
deleteDirectory($stagingDir);
echo "  Done.\n";

// Report.
$size = filesize($pharFile);
$sizeMB = round($size / 1024 / 1024, 2);
echo "\nBuild complete: {$pharFile}\n";
echo "Size: {$sizeMB} MB ({$size} bytes)\n";

// --- Helper functions ---

function addFile(Phar $phar, string $sourcePath, string $pharPath): void
{
	if (!file_exists($sourcePath))
	{
		fwrite(STDERR, "Warning: File not found, skipping: {$sourcePath}\n");
		return;
	}

	$phar->addFile($sourcePath, $pharPath);
}

function addDirectory(Phar $phar, string $sourceDir, string $pharPrefix, array $excludePatterns = []): void
{
	if (!is_dir($sourceDir))
	{
		fwrite(STDERR, "Warning: Directory not found, skipping: {$sourceDir}\n");
		return;
	}

	$iterator = new RecursiveIteratorIterator(
		new RecursiveDirectoryIterator(
			$sourceDir,
			FilesystemIterator::SKIP_DOTS
		),
		RecursiveIteratorIterator::LEAVES_ONLY
	);

	$count = 0;

	foreach ($iterator as $file)
	{
		if (!$file->isFile())
		{
			continue;
		}

		$filePath     = $file->getPathname();
		$relativePath = substr($filePath, strlen($sourceDir) + 1);

		// Check exclusion patterns.
		$excluded = false;

		foreach ($excludePatterns as $pattern)
		{
			if (str_contains('/' . $relativePath . '/', $pattern))
			{
				$excluded = true;
				break;
			}
		}

		if ($excluded)
		{
			continue;
		}

		$phar->addFile($filePath, $pharPrefix . '/' . $relativePath);
		$count++;
	}

	echo "  Added {$count} files from {$pharPrefix}/\n";
}

function deleteDirectory(string $dir): void
{
	if (!is_dir($dir))
	{
		return;
	}

	$iterator = new RecursiveIteratorIterator(
		new RecursiveDirectoryIterator($dir, FilesystemIterator::SKIP_DOTS),
		RecursiveIteratorIterator::CHILD_FIRST
	);

	foreach ($iterator as $file)
	{
		if ($file->isDir())
		{
			rmdir($file->getPathname());
		}
		else
		{
			unlink($file->getPathname());
		}
	}

	rmdir($dir);
}
