{
	"name": "nikosdion/joomla-mcp-php",
	"description": "An MCP server for Joomla 5 and later, written in PHP",
	"minimum-stability": "stable",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "Nicholas K. Dionysopoulos",
			"email": "nicholas@dionysopoulos.me"
		}
	],
	"require": {
		"php": ">=8.1",
		"ext-json": "*",
		"ext-curl": "*",
		"composer/ca-bundle": ">=1.5.7",
		"douglasgreen/opt-parser": "^v0.5.0",
		"joomla/http": "^3.0.0",
		"joomla/uri": "^3.0.2",
		"league/commonmark": "^2.7.1",
		"monolog/monolog": "^3.9.0",
		"php-mcp/server": "^3.3.0",
		"pimple/pimple": "^3.4.0",
		"symfony/polyfill-iconv": "^1.32"
	},
	"config":
	{
		"platform": {
			"php": "8.1.999"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"Dionysopoulos\\Mcp4Joomla\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Dionysopoulos\\Mcp4Joomla\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"compile": "php -d phar.readonly=0 bin/compile",
		"test": "phpunit",
		"test:unit": "phpunit --testsuite Unit",
		"test:integration": "phpunit --testsuite Integration"
	}
}
