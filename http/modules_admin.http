### List administrator modules
GET {{baseUrl}}/api/index.php/v1/modules/administrator
Authorization: Bearer {{token}}
Accept: application/vnd.api+json

### List administrator modules, with filters
# Filters:
# - filter[search]    string  Search by module title
# - filter[state]     int     0=unpublished, 1=published, 2=archived, -2=trashed
# - filter[position]  int     Module position
# - filter[module]    string  Module type (e.g. mod_menu)
# - filter[access]    int     Access level
GET {{baseUrl}}/api/index.php/v1/modules/administrator?filter[state]=1
Authorization: Bearer {{token}}
Accept: application/vnd.api+json

### Get administrator module data
GET {{baseUrl}}/api/index.php/v1/modules/administrator/1
Authorization: Bearer {{token}}
Accept: application/vnd.api+json

### List available administrator module types
GET {{baseUrl}}/api/index.php/v1/modules/types/administrator
Authorization: Bearer {{token}}
Accept: application/vnd.api+json

### Create administrator module
POST {{baseUrl}}/api/index.php/v1/modules/administrator
Authorization: Bearer {{token}}
Accept: application/vnd.api+json
Content-Type: application/json

{
	"title": "Test Admin Module",
	"module": "mod_custom",
	"published": 1,
	"language": "*"
}

### Update administrator module
PATCH {{baseUrl}}/api/index.php/v1/modules/administrator/1
Authorization: Bearer {{token}}
Accept: application/vnd.api+json
Content-Type: application/json

{
	"published": 0
}

### Delete administrator module (must be trashed first)
DELETE {{baseUrl}}/api/index.php/v1/modules/administrator/1
Authorization: Bearer {{token}}
Accept: application/vnd.api+json
